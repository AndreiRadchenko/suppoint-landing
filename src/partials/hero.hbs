<!-- ── 1. HERO ──────────────────────────────────────────────────────── -->
<header
  class="relative min-h-screen flex items-center justify-center pt-32 pb-20 px-margin-mobile overflow-hidden"
>
  <!-- BG image -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <picture>
      <source media="(max-width: 767px)" srcset="/src/assets/images/hero-lake-mobile.webp" />
      <source media="(min-width: 768px)" srcset="/src/assets/images/hero-lake-desktop.webp" />
      <img
        alt="Paddleboarders on a serene alpine lake at sunset"
        class="w-full h-full object-cover scale-110 brightness-110"
        src="/src/assets/images/hero-lake-desktop.webp"
      />
    </picture>
    <div
      class="absolute inset-0 bg-gradient-to-b from-background/30 via-background/10 to-background"
    ></div>
  </div>

  <!-- Glass card -->
  <div
    class="relative z-10 liquid-glass max-w-4xl w-full p-10 md:p-20 rounded-[3rem] text-center flex flex-col items-center gap-10 animate-float-slow"
  >
    <div class="space-y-6">
      <span
        class="inline-block px-6 py-1.5 rounded-full bg-secondary/10 text-secondary border border-secondary/20 font-label-bold text-label-bold uppercase tracking-[0.2em]"
        data-i18n="premiumSupRental"
      >
        Premium SUP Rental
      </span>
      <h1
        class="font-headline-lg text-headline-mobile md:text-headline-lg text-primary text-glow-dark leading-none"
        data-i18n="heroTitle"
      >
        Автоматизований<br />прокат сапбордів
      </h1>
      <p
        class="text-body-lg text-on-surface-variant max-w-xl mx-auto leading-relaxed"
        data-i18n="heroSubtitle"
      >
        Насолоджуйтесь активним відпочинком на воді без черг та очікувань. Повністю
        автоматизована система оренди через Telegram-бот.
      </p>
    </div>
    <a
      href="https://telegram.me/SUPPOINT_RentalBot"
      target="_blank"
      rel="noopener"
      class="sunny-btn px-10 md:px-14 py-5 md:py-6 text-base md:text-xl gap-4"
    >
      <span data-i18n="bookNow">ЗАБРОНЮВАТИ</span>
      <span class="material-symbols-outlined text-2xl">rocket_launch</span>
    </a>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 text-primary/40 animate-bounce flex flex-col items-center gap-2"
  >
    <span class="font-label-bold text-[11px] uppercase tracking-[0.3em]" data-i18n="scrollToExplore"
      >Scroll to explore</span
    >
    <span class="material-symbols-outlined">expand_more</span>
  </div>
</header>
