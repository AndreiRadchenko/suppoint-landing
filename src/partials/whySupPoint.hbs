<!-- ── 6. WHY SUPPOINT — bento ─────────────────────────────────────── -->
<section class="py-12 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
  <div class="mb-16 text-center lg:text-left">
    <h2
      class="font-headline-lg text-headline-mobile md:text-headline-lg text-primary mb-4"
      data-i18n="whySupPoint.title"
