    <div class="w-24 h-1.5 bg-sunny-accent rounded-full mx-auto lg:mx-0"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
    <!-- Big card -->
    <div
      class="md:col-span-8 liquid-glass p-10 md:p-14 rounded-[3rem] relative overflow-hidden group min-h-[380px] flex flex-col justify-between"
    >
      <div class="relative z-10 space-y-6">
        <span
          class="material-symbols-outlined text-sunny-accent text-6xl"
          style="filter: drop-shadow(0 0 20px rgba(255, 165, 0, 0.2))"
