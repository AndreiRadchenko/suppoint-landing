    <!-- Wide card: 24/7 -->
    <div
      class="md:col-span-8 liquid-glass p-10 rounded-[3rem] flex items-center gap-10 overflow-hidden"
    >
      <div class="flex-1">
        <h3
          class="font-headline-lg text-2xl text-primary mb-3"
          data-i18n="whySupPoint.alwaysOpen.title"
          >Доступно 24/7</h3
