        </p>
      </div>
      <div
        class="absolute right-0 bottom-0 opacity-5 group-hover:opacity-10 transition-opacity pointer-events-none"
      >
        <span
          class="material-symbols-outlined text-[250px] leading-none translate-y-1/4 translate-x-1/4 text-primary"
          >smart_toy</span
        >
      </div>
    </div>

    <!-- Small card: easy start -->
    <div
      class="md:col-span-4 liquid-glass p-9 rounded-[3rem] flex flex-col gap-5 group hover:border-secondary/50 transition-colors"
