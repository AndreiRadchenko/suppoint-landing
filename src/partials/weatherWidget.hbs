<!-- ── 2. WEATHER WIDGET ────────────────────────────────────────────── -->
<section class="py-16 bg-surface-container-low/40">
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div
      class="liquid-glass p-8 md:p-14 rounded-[3rem] flex flex-wrap justify-around items-center gap-10"
    >
      <div class="text-center md:text-left">
        <h3 class="font-headline-lg text-2xl md:text-3xl text-primary mb-2" data-i18n="todayWeather"
          >Погода сьогодні</h3
        >
        <p class="text-on-surface-variant flex items-center gap-2 justify-center md:justify-start">
          <span class="material-symbols-outlined text-secondary">location_on</span>
          <span id="weather-location" data-i18n="location">Київ, Парк Муромець</span>
        </p>
      </div>
      <div class="flex items-center gap-10 md:gap-16 flex-wrap justify-center">
        <div class="flex flex-col items-center gap-2">
          <span
            class="material-symbols-outlined text-5xl h-[60px] flex items-center justify-center text-sunny-accent"
            style="line-height: 60px; filter: drop-shadow(0 0 15px rgba(255, 165, 0, 0.3))"
            >device_thermostat</span
          >
          <span id="weather-temp" class="text-2xl font-black text-primary">+25°C</span>
          <span
            class="text-xs uppercase tracking-widest text-on-surface-variant/60"
            data-i18n="temperature"
            >Повітря</span
          >
        </div>
        <div class="flex flex-col items-center gap-2">
          <img id="weather-icon" src="" alt="Weather icon" class="w-[60px] h-[60px] object-contain" />
          <span id="weather-water-temp" class="text-2xl font-black text-primary">+21°C</span>
          <span
            class="text-xs uppercase tracking-widest text-on-surface-variant/60"
            data-i18n="waterTemp"
          ></span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span
            class="material-symbols-outlined text-5xl h-[60px] flex items-center justify-center text-primary/60"
            style="line-height: 60px; filter: drop-shadow(0 0 15px rgba(255, 165, 0, 0.3))"
            >air</span
          >
          <span id="weather-wind" class="text-2xl font-black text-primary">3–5 м/с</span>
          <span
            class="text-xs uppercase tracking-widest text-on-surface-variant/60"
            data-i18n="wind"
            >Вітер</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
